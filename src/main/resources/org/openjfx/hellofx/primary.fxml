<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.openjfx.hellofx.PrimaryController">
    <center>
        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-border-color: lightgray; -fx-border-width: 1;">
            <children>
                <Label text="Input Files" style="-fx-font-size: 16px; -fx-padding: 8 0 0 0;" />
                <ListView fx:id="fileListView" prefHeight="400.0" prefWidth="600.0" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10.0" alignment="CENTER">
            <children>
                <Button text="파일추가" onAction="#handleAddFile" />
                <Button text="파일삭제" onAction="#handleDeleteFile" />
                <Button text="로그분석" onAction="#handleAnalyze" />
                <Button text="결과확인" onAction="#handleViewResults" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="20.0" left="10.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
