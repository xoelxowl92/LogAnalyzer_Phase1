<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.openjfx.hellofx.PrimaryController"
            prefWidth="1100" prefHeight="750">

    <!-- 사이드바 -->
    <left>
        <VBox styleClass="sidebar">

            <!-- 로고 -->
            <HBox styleClass="logo-area" alignment="CENTER_LEFT" spacing="8">
                <Label text="✕" styleClass="logo-icon"/>
                <VBox>
                    <Label text="LogAnalyzer" styleClass="logo-title"/>
                    <Label text="for chimanthi" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <!-- 메뉴 -->
            <HBox fx:id="navAnalyze" styleClass="nav-item" onMouseClicked="#handleNavAnalyze"
                  spacing="8" alignment="CENTER_LEFT">
                <Label text="분석" styleClass="nav-label"/>
            </HBox>
            <HBox fx:id="navHistory" styleClass="nav-item, nav-item-selected"
                  onMouseClicked="#handleNavHistory" spacing="8" alignment="CENTER_LEFT">
                <Label text="히스토리" styleClass="nav-label"/>
            </HBox>

            <!-- 히스토리 목록 -->
            <VBox fx:id="historyList"/>

        </VBox>
    </left>

    <!-- 메인 콘텐츠 -->
    <center>
        <VBox styleClass="main-content" alignment="CENTER" spacing="12">
            <HBox spacing="8" alignment="CENTER">
                <TextField fx:id="filePathField" styleClass="upload-field"
                           promptText="Upload File" onMouseClicked="#handleFieldClick"/>
                <Button text="Analyze" styleClass="analyze-button" onAction="#handleAnalyze"/>
            </HBox>
            <HBox alignment="CENTER">
                <VBox spacing="8" alignment="CENTER_LEFT" prefWidth="358">
                    <padding><Insets top="8"/></padding>
                    <CheckBox fx:id="checkSuspectedLogs" text="Suspected Logs"
                              styleClass="option-checkbox" selected="true"/>
                    <CheckBox fx:id="checkAnomalyDetect" text="Anomaly Detect"
                              styleClass="option-checkbox"/>
                    <CheckBox fx:id="checkLogInsights" text="Log Insights"
                              styleClass="option-checkbox" selected="true"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>
