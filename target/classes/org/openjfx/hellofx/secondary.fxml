<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.openjfx.hellofx.SecondaryController">
    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="Results" />
                <TextArea fx:id="resultsTextArea" prefHeight="400.0" prefWidth="600.0" wrapText="true" editable="false" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER">
            <children>
                <Button text="뒤로가기" onAction="#switchToPrimary" />
            </children>
            <padding>
                <Insets top="10.0" right="10.0" bottom="20.0" left="10.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
